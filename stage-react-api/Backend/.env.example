NODE_ENV=development
PORT=3000

# MongoDB Atlas connection string (create a free cluster at https://www.mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/news-explorer

# Secret used to sign/verify JWTs. Required in production; a fallback dev secret
# is used automatically when NODE_ENV !== 'production'.
JWT_SECRET=replace-with-a-long-random-string

# Comma-separated list of origins allowed to send credentialed requests
CLIENT_ORIGIN=http://localhost:5173
